{
  "enabled": false,
  "model": {
    "base_url": "https://api.deepseek.com/v1",
    "api_key": "",
    "model": "deepseek-chat",
    "temperature": 0.7,
    "top_p": 1.0,
    "max_tokens": 1024,
    "timeout_seconds": 60,
    "proxy": ""
  },
  "persona": {
    "skill_path": "BotData/agent_personas/default",
    "max_chars": 12000,
    "fallback_prompt": "你是 HIKARI BOT 的聊天 AI Agent。请自然、简洁地回复用户。"
  },
  "chat": {
    "max_user_chars": 2000,
    "max_reply_chars": 3500,
    "max_history_messages": 10,
    "cooldown_seconds": 3,
    "system_prompt_extra": "",
    "blocked_url_domains": [
      "douyin.com",
      "iesdouyin.com",
      "bilibili.com",
      "b23.tv",
      "xiaohongshu.com",
      "xhslink.com",
      "xiaoheihe.cn",
      "heybox.cn",
      "twitter.com",
      "x.com",
      "t.co",
      "toutiao.com",
      "ixigua.com",
      "kuaishou.com",
      "gifshow.com",
      "weibo.com",
      "weibo.cn",
      "tiktok.com",
      "vm.tiktok.com"
    ]
  },
  "memory": {
    "enabled": true,
    "root": "UserData/aiagent_memory",
    "max_read_chars_per_file": 8000,
    "max_file_chars": 60000
  }
}
