# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment files (forbidden in this project)
.env
.env.*
!.env.example
dotenv*

# Config files with secrets (templates in *.example.json)
BotData/config.json
BotData/plugin_configs/*.json
!BotData/plugin_configs/*.example.json
BotData/resources/*.json
!BotData/resources/*.example.json
BotData/fonts/*
!BotData/fonts/.gitkeep
BotData/agent_personas/*
!BotData/agent_personas/.gitkeep

# Gifs: keep directory structure, ignore actual media
BotData/Gifs/*/**
!BotData/Gifs/**/.gitkeep

# Voices: keep directory structure, ignore actual media
BotData/Voices/*/**
!BotData/Voices/**/.gitkeep

# Logs (history logs on dev machine)
BotData/logs/*.log
!BotData/logs/.gitkeep

# User data (sensitive)
UserData/private/*.jsonl
UserData/group/*.jsonl
UserData/stats/
UserData/rss_subscriber_state.json
!UserData/.gitkeep

# Local deployment legal documents
USER_AGREEMENT.local.md
PRIVACY_POLICY.local.md

# System
.DS_Store
Thumbs.db

# MyPy / PyTest
.mypy_cache/
.pytest_cache/
.python-version

# Temporary media
/tmp/hikari_bot/
/runtime/
deploy-source-files-*.txt

# Docker runtime data
astrbot/
napcat/
sharedFolder/
!sharedFolder/
!sharedFolder/.gitkeep
tmp/
legacy/
